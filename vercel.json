{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "ignoreCommand": "if [ \"$VERCEL_ENV\" = \"production\" ]; then exit 1; else exit 0; fi",
  "git": {
    "deploymentEnabled": true
  },
  "crons": [
    {
      "path": "/api/cron/drive-video-scan",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/daily-report",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/weekly-insights",
      "schedule": "0 9 * * 1"
    },
    {
      "path": "/api/cron/renew-webhooks",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/update-student-status",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/weekly-digest",
      "schedule": "0 18 * * 0"
    },
    {
      "path": "/api/cron/cleanup-auth-events",
      "schedule": "30 3 * * *"
    }
  ]
}
