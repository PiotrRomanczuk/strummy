{
  "name": "@strummy/mcp-server",
  "version": "0.1.0",
  "description": "Local MCP server exposing Strummy domain operations (students, lessons, songs, repertoire) to MCP clients.",
  "private": true,
  "type": "module",
  "bin": {
    "strummy-mcp-server": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "smoke": "tsx tests/smoke.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.20.0",
    "@supabase/supabase-js": "^2.45.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsx": "^4.20.0",
    "typescript": "^5"
  }
}
