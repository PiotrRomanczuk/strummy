# Strummy MCP server — environment.
# Local stdio transport. Service-role key bypasses RLS — DO NOT expose remotely.

# Point at local or remote Supabase. Local example:
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=

# Optional: limit by environment label in tool responses.
STRUMMY_ENV=local
