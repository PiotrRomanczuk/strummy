meta {
  name: get-auth-no-token
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/api/lessons
  auth: none
}

docs {
  Verifies that any authenticated route returns 401 when called with no token.
  Uses /api/lessons as a stable, always-authenticated endpoint.
}

tests {
  test('No token returns 401', function() {
    expect(res.status).to.equal(401);
  });
  test('Error message present', function() {
    expect(res.body).to.have.property('error');
  });
}
