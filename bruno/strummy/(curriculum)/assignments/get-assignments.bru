meta {
  name: get-assignments
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/api/assignments
  auth: inherit
}

tests {
  test("status 200", function() {
    expect(res.status).to.equal(200);
  });
  test("has assignments array", function() {
    expect(res.body).to.have.property("assignments");
    expect(res.body.assignments).to.be.an("array");
  });
}

docs {
  Domain assignments. Auth user. schemas=AssignmentSchema
}
