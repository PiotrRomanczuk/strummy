meta {
  name: post-song-favorites
  type: http
  seq: 15
}

post {
  url: {{baseUrl}}/api/song/favorites
  body: json
  auth: inherit
}

body:json {
  {
    "song_id": "{{sample_song_id}}"
  }
}

tests {
  test('Status 200 or 201 or 409 or 500', function() {
    expect([200, 201, 400, 409, 500]).to.include(res.status);
  });
  test('Response is not auth error', function() {
    expect(res.status).to.not.equal(401);
    expect(res.status).to.not.equal(403);
  });
}