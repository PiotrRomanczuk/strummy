meta {
  name: get-song-id-videos
  type: http
  seq: 9
}

get {
  url: {{baseUrl}}/api/song/{{sample_song_id}}/videos
  auth: inherit
}

tests {
  test('Status 200', function() {
    expect(res.status).to.equal(200);
  });
  test('Response has videos array', function() {
    expect(res.body).to.have.property('videos');
    expect(res.body.videos).to.be.an('array');
  });
}