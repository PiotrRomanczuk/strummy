meta {
  name: get-song-favorites
  type: http
  seq: 5
}

get {
  url: {{baseUrl}}/api/song/favorites?userId={{sample_student_id}}
  auth: inherit
}

tests {
  test('Status 200', function() {
    expect(res.status).to.equal(200);
  });
  test('Response has favorites', function() {
    expect(res.body).to.have.property('favorites');
    expect(res.body.favorites).to.be.an('array');
  });
}