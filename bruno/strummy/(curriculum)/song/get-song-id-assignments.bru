meta {
  name: get-song-id-assignments
  type: http
  seq: 7
}

get {
  url: {{baseUrl}}/api/song/{{sample_song_id}}/assignments
  auth: inherit
}

tests {
  test('Status 200', function() {
    expect(res.status).to.equal(200);
  });
  test('Response has assignments array', function() {
    expect(res.body).to.have.property('assignments');
    expect(res.body.assignments).to.be.an('array');
  });
}