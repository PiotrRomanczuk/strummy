meta {
  name: get-song-id-lessons
  type: http
  seq: 8
}

get {
  url: {{baseUrl}}/api/song/{{sample_song_id}}/lessons
  auth: inherit
}

tests {
  test('Status 200', function() {
    expect(res.status).to.equal(200);
  });
  test('Response has lessons array', function() {
    expect(res.body).to.have.property('lessons');
    expect(res.body.lessons).to.be.an('array');
  });
}