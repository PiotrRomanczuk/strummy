meta {
  name: get-lessons-templates
  type: http
  seq: 9
}

get {
  url: {{baseUrl}}/api/lessons/templates
  auth: inherit
}

tests {
  test('Status 200', function() {
    expect(res.status).to.equal(200);
  });
  test('Response has templates array', function() {
    expect(res.body).to.have.property('templates');
    expect(res.body.templates).to.be.an('array');
  });
}