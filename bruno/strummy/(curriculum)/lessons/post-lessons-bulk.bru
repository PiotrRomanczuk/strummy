meta {
  name: post-lessons-bulk
  type: http
  seq: 15
}

post {
  url: {{baseUrl}}/api/lessons/bulk
  body: json
  auth: inherit
}

body:json {
  {
    "lessons": [
      {
        "teacher_id": "{{sample_teacher_id}}",
        "student_id": "{{sample_student_id}}",
        "scheduled_at": "2026-07-01T10:00:00.000Z",
        "status": "SCHEDULED"
      }
    ]
  }
}

tests {
  test('Status 200 or 201', function() {
    expect([200, 201]).to.include(res.status);
  });
}