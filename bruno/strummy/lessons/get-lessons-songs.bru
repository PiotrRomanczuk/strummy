meta {
  name: get-lessons-songs
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/api/lessons/songs?lessonId={{sample_lesson_id}}
  auth: inherit
}

tests {
  test('Status 200', function() {
    expect(res.status).to.equal(200);
  });
  test('Response has lessonSongs array', function() {
    expect(res.body).to.have.property('lessonSongs');
    expect(res.body.lessonSongs).to.be.an('array');
  });
}