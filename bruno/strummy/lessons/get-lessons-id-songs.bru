meta {
  name: get-lessons-id-songs
  type: http
  seq: 5
}

get {
  url: {{baseUrl}}/api/lessons/{{sample_lesson_id}}/songs
  auth: inherit
}

tests {
  test('Status 200', function() {
    expect(res.status).to.equal(200);
  });
  test('Response has songs array', function() {
    expect(res.body).to.have.property('songs');
    expect(res.body.songs).to.be.an('array');
  });
}