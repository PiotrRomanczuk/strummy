meta {
  name: get-lessons-export
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/api/lessons/export?format=json
  auth: inherit
}

tests {
  test('Status 200', function() {
    expect(res.status).to.equal(200);
  });
  test('Response has lessons array', function() {
    expect(res.body).to.have.property('lessons');
    expect(res.body.lessons).to.be.an('array');
  });
}
